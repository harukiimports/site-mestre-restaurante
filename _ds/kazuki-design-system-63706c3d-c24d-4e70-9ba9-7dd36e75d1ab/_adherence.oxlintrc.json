{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/core/**",
              "components/social/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Playfair Display|Montserrat))/i]",
        "message": "Font not provided by the design system. Available: Playfair Display, Montserrat."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:gold|solid|blood|ghost)$/]",
        "message": "<Badge> variant must be one of 'gold' | 'solid' | 'blood' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|iconRight|fullWidth|disabled|style|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, iconRight, fullWidth, disabled, style, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:gold|blood|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'gold' | 'blood' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|bordered|pattern|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, tone, bordered, pattern, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:card|raised|canvas)$/]",
        "message": "<Card> tone must be one of 'card' | 'raised' | 'canvas'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Crest'] > JSXAttribute > JSXIdentifier[name!=/^(?:layout|wordmark|slogan|crestSize|src|style|key|ref|className|style|children)$/]",
        "message": "<Crest> doesn't accept that prop. Declared props: layout, wordmark, slogan, crestSize, src, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Crest'] > JSXAttribute[name.name='layout'] > Literal[value!=/^(?:horizontal|stacked)$/]",
        "message": "<Crest> layout must be one of 'horizontal' | 'stacked'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|rule|color|style|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, rule, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='rule'] > Literal[value!=/^(?:none|left|right|both)$/]",
        "message": "<Eyebrow> rule must be one of 'none' | 'left' | 'right' | 'both'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:gold|bone|blood)$/]",
        "message": "<Eyebrow> color must be one of 'gold' | 'bone' | 'blood'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KatanaDivider'] > JSXAttribute > JSXIdentifier[name!=/^(?:width|color|glyph|style|key|ref|className|style|children)$/]",
        "message": "<KatanaDivider> doesn't accept that prop. Declared props: width, color, glyph, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='OrnamentalFrame'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|inset|cornerSize|color|doubleLine|style|key|ref|className|style|children)$/]",
        "message": "<OrnamentalFrame> doesn't accept that prop. Declared props: children, inset, cornerSize, color, doubleLine, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PriceTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:price|was|currency|align|size|style|key|ref|className|style|children)$/]",
        "message": "<PriceTag> doesn't accept that prop. Declared props: price, was, currency, align, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PriceTag'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center|right)$/]",
        "message": "<PriceTag> align must be one of 'left' | 'center' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PriceTag'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<PriceTag> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PromoSeal'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|caption|size|variant|rotate|style|key|ref|className|style|children)$/]",
        "message": "<PromoSeal> doesn't accept that prop. Declared props: value, caption, size, variant, rotate, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PromoSeal'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:blood|gold)$/]",
        "message": "<PromoSeal> variant must be one of 'blood' | 'gold'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SocialBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:networks|handle|size|variant|align|style|key|ref|className|style|children)$/]",
        "message": "<SocialBar> doesn't accept that prop. Declared props: networks, handle, size, variant, align, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SocialBar'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:gold|outline)$/]",
        "message": "<SocialBar> variant must be one of 'gold' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SocialBar'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:center|left)$/]",
        "message": "<SocialBar> align must be one of 'center' | 'left'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
